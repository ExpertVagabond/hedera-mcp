# Hedera network: mainnet | testnet | previewnet  (default: testnet)
HEDERA_NETWORK=testnet

# Optional. Default payer / treasury account used when building write transactions.
# Only an ACCOUNT ID is needed — this server never holds or asks for a private key.
# If unset, write tools require an explicit `payerAccountId` argument.
HEDERA_OPERATOR_ID=0.0.xxxxxx

# Optional override for the Mirror Node REST base URL (e.g. a private/HGraph endpoint).
# HEDERA_MIRROR_URL=https://testnet.mirrornode.hedera.com
